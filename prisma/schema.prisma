generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ORGANIZER
  VENDOR
  ATTENDEE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
}

enum EventStaffRole {
  OWNER
  OPERATIONS
  CHECK_IN
  SECURITY
  STAGE_MANAGER
  VENDOR_MANAGER
}

enum StaffPermission {
  SCAN_QR
  VERIFY_PASS
  SEARCH_ATTENDEE
  VIEW_DASHBOARD
  VIEW_ACTIVITY
  SEND_NOTIFICATION
  SEND_ANNOUNCEMENT
  MANAGE_STAFF
  MANAGE_VENDORS
  VIEW_REPORTS
  EDIT_EVENT
}

model User {
  id String @id @default(cuid())

  firstName String
  lastName  String

  email    String @unique
  password String

  phone String?

  role UserRole

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketCheckIns TicketCheckIn[]

  organization Organization?

  purchases TicketPurchase[]

  registrations Registration[]

  deviceTokens DeviceToken[]

  notifications Notification[]

  attendeeProfile AttendeeProfile?
}

model Organization {
  id String @id @default(cuid())

  name String

  slug String @unique

  logo String?

  ownerId String @unique

  owner User @relation(fields: [ownerId], references: [id])

  events Event[]

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id String @id @default(cuid())

  title       String
  description String

  venue String

  coverImage String?

  capacity Int

  currency String @default("USD")

  startDate DateTime
  endDate   DateTime

  status EventStatus @default(DRAFT)

  organizationId String

  tickets TicketType[]

  staff EventStaff[]

  activities EventActivity[]

  purchases TicketPurchase[]

  sessions Session[]

  announcements Announcement[]

  isPublic Boolean @default(true)

  registrations Registration[]

  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  VendorApplication VendorApplication[]
}

model Registration {
  id String @id @default(cuid())

  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model AttendeeProfile {
  id String @id @default(cuid())

  userId String @unique

  profession String?
  industry   String?

  goals  Json?
  skills Json?

  linkedin String?
  company  String?
  jobTitle String?
  avatar   String?

  bio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model TicketType {
  id String @id @default(cuid())

  eventId String

  name String

  price Float

  quantity Int

  description String?
  color       String?
  benefits    Json?

  sold Int @default(0)

  purchases TicketPurchase[]

  isActive Boolean @default(true)

  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorApplication {
  id String @id @default(cuid())

  eventId String

  businessName String

  category String

  contactName String

  email String

  phone String

  description String

  boothSize String?

  status VendorStatus @default(PENDING)

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}

model TicketPurchase {
  id String @id @default(cuid())

  userId String

  eventId String

  ticketTypeId String

  quantity Int

  amount Float

  paymentMethod String?
  currency      String  @default("USD")

  stripeSessionId String?

  checkIn TicketCheckIn?

  status PurchaseStatus @default(PENDING)

  createdAt DateTime @default(now())

  checkedIn Boolean @default(false)

  checkedInAt DateTime?

  user User @relation(fields: [userId], references: [id])

  event Event @relation(fields: [eventId], references: [id])

  ticket    TicketType @relation(fields: [ticketTypeId], references: [id])
  EventPass EventPass?
}

model EventPass {
  id              String    @id @default(cuid())
  passNumber      String    @unique
  purchaseId      String    @unique
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastGeneratedAt DateTime?
  expiresAt       DateTime?

  purchase TicketPurchase @relation(fields: [purchaseId], references: [id])
}

model TicketCheckIn {
  id String @id @default(cuid())

  purchaseId String @unique

  checkedInBy String

  station String?

  deviceId String?

  checkedInAt DateTime @default(now())

  purchase TicketPurchase @relation(fields: [purchaseId], references: [id])

  organizer User @relation(fields: [checkedInBy], references: [id])
}

model EventStaff {
  id String @id @default(cuid())

  eventId String

  name String

  phone String?

  email String?

  role EventStaffRole

  station String?

  accessCode String @unique

  sessions OperationSession[]

  permissions StaffPermission[]

  isActive Boolean @default(true)

  isRevoked Boolean @default(false)

  invitedBy String?

  acceptedAt DateTime?

  expiresAt DateTime?

  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([accessCode])
  @@index([eventId, isActive])
}

model Notification {
  id String @id @default(cuid())

  userId String

  title String

  body String

  read Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DeviceToken {
  id String @id @default(cuid())

  userId String

  token String @unique

  platform String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Announcement {
  id String @id @default(cuid())

  eventId String

  title String

  message String

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}

model Session {
  id String @id @default(cuid())

  eventId String

  title String

  speaker String?

  venue String?

  startTime DateTime

  endTime DateTime

  event Event @relation(fields: [eventId], references: [id])
}

model Connection {
  id String @id @default(cuid())

  requesterId String

  receiverId String

  accepted Boolean @default(false)

  createdAt DateTime @default(now())
}

model EventActivity {
  id String @id @default(cuid())

  eventId String

  actorId String?

  type String

  payload Json?

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}

model OperationSession {
  id String @id @default(cuid())

  staffId String

  token String @unique

  deviceId String?

  deviceName String?

  ipAddress String?

  startedAt DateTime @default(now())

  lastSeenAt DateTime @updatedAt

  endedAt DateTime?

  isActive Boolean @default(true)

  staff EventStaff @relation(fields: [staffId], references: [id])

  @@index([staffId])
}
