generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ORGANIZER
  VENDOR
  ATTENDEE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id String @id @default(cuid())

  firstName String
  lastName  String

  email    String @unique
  password String

  phone String?

  role UserRole

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization?

  registrations Registration[]

  attendeeProfile AttendeeProfile?
}

model Organization {
  id String @id @default(cuid())

  name String

  slug String @unique

  logo String?

  ownerId String @unique

  owner User @relation(fields: [ownerId], references: [id])

  events Event[]

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id String @id @default(cuid())

  title       String
  description String

  venue String

  coverImage String?

  capacity Int

  startDate DateTime
  endDate   DateTime

  status EventStatus @default(DRAFT)

  organizationId String

  tickets TicketType[]

  isPublic Boolean @default(true)

  registrations Registration[]

  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  VendorApplication VendorApplication[]
}

model Registration {
  id String @id @default(cuid())

  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model AttendeeProfile {
  id String @id @default(cuid())

  userId String @unique

  profession String?
  industry   String?

  goals  Json?
  skills Json?

  bio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model TicketType {
  id String @id @default(cuid())

  eventId String

  name String

  price Float

  quantity Int

  sold Int @default(0)

  isActive Boolean @default(true)

  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorApplication {
  id String @id @default(cuid())

  eventId String

  businessName String

  category String

  contactName String

  email String

  phone String

  description String

  boothSize String?

  status VendorStatus @default(PENDING)

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}
